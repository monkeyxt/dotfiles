#!/usr/bin/env bash
# osc52copy — copy text to the system clipboard via OSC 52 over SSH
set -euo pipefail

# ── helpers ──────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
Usage: $(basename "$0") [file]

Copy text to the local clipboard using OSC 52 via SSH.

  $(basename "$0") my_file.txt   # copy file contents
  echo 'hello' | $(basename "$0") # copy from stdin
EOF
    exit 1
}

die() { echo "Error: $*" >&2; exit 1; }

# ── dependency check ──────────────────────────────────────────────────────────

command -v base64 >/dev/null 2>&1 || die "'base64' not found. Please install coreutils."

# ── parse arguments ───────────────────────────────────────────────────────────

case "${1:-}" in
    -h|--help) usage ;;
    "")        input_data=$(cat) ;;          # read from stdin
    *)         [[ -f "$1" ]] || die "File '$1' not found."
               input_data=$(cat "$1") ;;     # read from file
esac

# ── guard: nothing to copy ────────────────────────────────────────────────────

[[ -n "${input_data:-}" ]] || exit 0

# ── encode and send OSC 52 sequence ──────────────────────────────────────────
# Format: ESC ] 52 ; c ; <base64> BEL
# Redirected to /dev/tty so the sequence reaches the terminal even through pipes.

b64=$(printf '%s' "$input_data" | base64 | tr -d '\n')
printf '\033]52;c;%s\a' "$b64" > /dev/tty
